# Supabase — Dashboard → Project Settings → API
# Copy this file to .env.local and fill in your values.

# Public (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server only — NEVER expose this. Used by API routes to bypass RLS for
# validated draft/admin writes. Dashboard → Project Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# The admin login code. Whoever enters this at the sign-in screen gets admin
# tools (and bootstraps the admin account on first use). Keep it secret; change
# it any time to rotate the admin login. Must be at least 6 characters.
ADMIN_ACCESS_CODE=change-me-admin-code

# Optional. Secures the Vercel Cron auto-pick endpoint (/api/draft/tick GET).
# Set this in Vercel Project Settings → Environment Variables; Vercel then sends
# it as a Bearer token on cron requests. Generate one: `openssl rand -hex 32`.
CRON_SECRET=your-random-cron-secret
